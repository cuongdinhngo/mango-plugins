# Secrets — never ship
.env
.env.*
*.pem
*.pfx
*.p12
*.key

# Per-project harness config (lives in the consuming project, not here)
.harness.json

# OS / editor cruft
.DS_Store

# Dependencies / build
node_modules/

# Python
__pycache__/
*.pyc

# Eval transcripts (teed by tests/eval/run.sh for inspection; regenerated each run)
tests/eval/.transcripts/

# Eval transcript-cache (last GREEN transcript per fixture+skills-hash; dev-loop only,
# --no-cache bypasses it; never committed — lives outside the tracked tree)
tests/eval/.cache/
